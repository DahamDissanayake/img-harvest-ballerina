# ===========================
# Ballerina Build Artifacts
# ===========================
# Generated during compilation; contains compiled artifacts and the executable.
target/

# Compiler-generated source code — remove this line if you want to commit generated sources.
generated/

# ===========================
# Secrets & Configuration
# ===========================
# Runtime config values (API keys, DB passwords, etc.) — never commit this.
# See https://ballerina.io/learn/provide-values-to-configurable-variables/
Config.toml

# Generic env files
.env
.env.local
.env.*

# ===========================
# Java / JAR Dependencies
# ===========================
# Ignore locally built or downloaded JARs in the libs folder.
# Commit only the JARs that are truly part of the repo (remove this line if needed).
libs/*.jar

# ===========================
# IDE & Editor
# ===========================
.vscode/
.idea/
*.iml
*.iws
*.ipr

# ===========================
# Dev Container
# ===========================
.devcontainer.json

# ===========================
# OS Artifacts
# ===========================
.DS_Store
Thumbs.db
*.log

# ===========================
# Test Artifacts
# ===========================
tests/target/
